<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>You've been added to a team</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background-color: #f5f5f5;
      color: #1a1a1a;
    }
    .wrapper {
      max-width: 580px;
      margin: 40px auto;
      background: #ffffff;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 4px 24px rgba(0,0,0,0.08);
    }
    .header {
      background-color: #0f0f0f;
      padding: 36px 40px;
      text-align: center;
    }
    .header .logo {
      font-size: 24px;
      font-weight: 900;
      color: #ffffff;
      letter-spacing: -0.5px;
    }
    .header .logo span {
      color: #f97316;
    }
    .body {
      padding: 40px;
    }
    .greeting {
      font-size: 22px;
      font-weight: 700;
      margin-bottom: 12px;
      color: #0f0f0f;
    }
    .intro {
      font-size: 15px;
      color: #555;
      line-height: 1.7;
      margin-bottom: 32px;
    }
    .card {
      background: #f9f9f9;
      border: 1px solid #ebebeb;
      border-radius: 12px;
      padding: 24px;
      margin-bottom: 32px;
    }
    .card-row {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 16px;
    }
    .card-row:last-child {
      margin-bottom: 0;
    }
    .card-icon {
      width: 36px;
      height: 36px;
      border-radius: 8px;
      background: #0f0f0f;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      font-size: 16px;
    }
    .card-label {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #999;
      margin-bottom: 2px;
    }
    .card-value {
      font-size: 15px;
      font-weight: 600;
      color: #0f0f0f;
    }
    .role-badge {
      display: inline-block;
      padding: 4px 12px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      background: #0f0f0f;
      color: #ffffff;
    }
    .cta-btn {
      display: block;
      width: 100%;
      padding: 16px;
      background: #f97316;
      color: #ffffff;
      text-align: center;
      font-size: 15px;
      font-weight: 700;
      text-decoration: none;
      border-radius: 10px;
      margin-bottom: 32px;
      letter-spacing: 0.02em;
    }
    .divider {
      border: none;
      border-top: 1px solid #ebebeb;
      margin-bottom: 24px;
    }
    .note {
      font-size: 13px;
      color: #888;
      line-height: 1.6;
      margin-bottom: 8px;
    }
    .footer {
      background: #f9f9f9;
      padding: 24px 40px;
      text-align: center;
      border-top: 1px solid #ebebeb;
    }
    .footer p {
      font-size: 12px;
      color: #aaa;
      line-height: 1.6;
    }
    .footer a {
      color: #f97316;
      text-decoration: none;
      font-weight: 600;
    }
    .business_name {
      color: #f97316;
      text-decoration: none;
      font-weight: 600;
    }
  </style>
</head>
<body>
  <div class="wrapper">

    <!-- Header -->
    <div class="header">
      <div class="logo">send<span>rey</span></div>
    </div>

    <!-- Body -->
    <div class="body">
      <p class="greeting">Hi {{name}}, you've been added to a team 🎉</p>
      <p class="intro">
        You've been invited to join <strong class="business_name">{{businessName}}</strong> on Sendrey.
        You now have access to their team workspace with the role assigned below.
      </p>

      <!-- Details Card -->
      <div class="card">
        <div class="card-row">
          <div>
            <div class="card-label">Business</div>
            <div class="card-value">{{businessName}}</div>
          </div>
        </div>
        

        <hr style="border:none; border-top:1px solid #e5e5e5; margin: 16px 0;" />


        <div class="card-row">
          <div>
            <div class="card-label">Your Role</div>
            <div class="card-value">
              <span class="role-badge">{{role}}</span>
            </div>
          </div>
        </div>
      </div>

      <!-- CTA -->
      <a href="{{loginUrl}}" class="cta-btn">Log In to Sendrey →</a>

      <hr class="divider" />

      <p class="note">
        If you already have a Sendrey account, simply log in and you'll see the team workspace. 
        If you don't have an account yet, you'll need to sign up with the email or phone this invite was sent to.
      </p>
      <p class="note">
        Not expecting this? You can safely ignore this email. If you have concerns, reach us at 
        <a href="mailto:{{supportEmail}}" style="color:#f97316;">{{supportEmail}}</a>.
      </p>
    </div>

    <!-- Footer -->
    <div class="footer">
      <p>© {{year}} Sendrey. All rights reserved.</p>
      <p style="margin-top:6px;">
        <a href="{{loginUrl}}">Log In</a> &nbsp;·&nbsp;
        <a href="mailto:{{supportEmail}}">Support</a>
      </p>
    </div>

  </div>
</body>
</html>