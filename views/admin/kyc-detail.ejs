<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: Arial, sans-serif; padding: 20px; background: #f5f5f5; }
        .container { max-width: 1200px; margin: 0 auto; background: white; padding: 30px; border-radius: 8px; }
        h1, h2 { color: #333; margin-bottom: 20px; }
        .back-btn { margin-bottom: 20px; }
        .section { margin-bottom: 30px; padding: 20px; border: 1px solid #ddd; border-radius: 4px; }
        .doc-image { max-width: 100%; max-height: 400px; object-fit: contain; border: 1px solid #ddd; padding: 10px; }
        .btn { padding: 10px 20px; border: none; border-radius: 4px; cursor: pointer; margin-right: 10px; }
        .btn-success { background: #4CAF50; color: white; }
        .btn-danger { background: #f44336; color: white; }
        .btn-secondary { background: #666; color: white; text-decoration: none; display: inline-block; }
        .info-row { margin: 10px 0; }
        .info-row label { font-weight: bold; display: inline-block; width: 150px; }
        textarea { width: 100%; padding: 10px; margin-top: 10px; }
    </style>
</head>
<body>
    <div class="container">
        <div class="back-btn">
            <a href="/admin/kyc" class="btn btn-secondary">← Back to Dashboard</a>
        </div>

        <h1>KYC Review: <%= runner.firstName %> <%= runner.lastName %></h1>

        <div class="section">
            <h2>Runner Information</h2>
            <div class="info-row"><label>Email:</label> <%= runner.email %></div>
            <div class="info-row"><label>Phone:</label> <%= runner.phone %></div>
            <div class="info-row"><label>Status:</label> <%= runner.runnerStatus %></div>
        </div>

        <% const docs = runner.runnerProfile?.verificationDocuments || {}; %>
        
        <!-- NIN Section -->
        <% if (docs.nin) { %>
        <div class="section">
            <h2>NIN Document</h2>
            <div class="info-row"><label>Number:</label> <%= docs.nin.number %></div>
            <div class="info-row"><label>Status:</label> <%= docs.nin.status %></div>
            <div class="info-row"><label>Submitted:</label> <%= new Date(docs.nin.submittedAt).toLocaleString() %></div>
            
            <% if (docs.nin.documentPath) { %>
                <img src="<%= docs.nin.documentPath %>" alt="NIN Document" class="doc-image">
            <% } %>
            
            <% if (docs.nin.status === 'pending_review') { %>
                <form method="POST" action="/admin/kyc/approve-document/<%= runner._id %>" style="display: inline;">
                    <input type="hidden" name="documentType" value="nin">
                    <button type="submit" class="btn btn-success">Approve NIN</button>
                </form>
                <form method="POST" action="/admin/kyc/reject-document/<%= runner._id %>" style="display: inline;">
                    <input type="hidden" name="documentType" value="nin">
                    <textarea name="reason" placeholder="Rejection reason..." required></textarea>
                    <button type="submit" class="btn btn-danger">Reject NIN</button>
                </form>
            <% } %>
        </div>
        <% } %>

        <!-- Driver License Section -->
        <% if (docs.driverLicense) { %>
        <div class="section">
            <h2>Driver License Document</h2>
            <div class="info-row"><label>Number:</label> <%= docs.driverLicense.number %></div>
            <div class="info-row"><label>Status:</label> <%= docs.driverLicense.status %></div>
            <div class="info-row"><label>Submitted:</label> <%= new Date(docs.driverLicense.submittedAt).toLocaleString() %></div>
            
            <% if (docs.driverLicense.documentPath) { %>
                <img src="<%= docs.driverLicense.documentPath %>" alt="Driver License Document" class="doc-image">
            <% } %>
            
            <% if (docs.driverLicense.status === 'pending_review') { %>
                <form method="POST" action="/admin/kyc/approve-document/<%= runner._id %>" style="display: inline;">
                    <input type="hidden" name="documentType" value="driverLicense">
                    <button type="submit" class="btn btn-success">Approve License</button>
                </form>
                <form method="POST" action="/admin/kyc/reject-document/<%= runner._id %>" style="display: inline;">
                    <input type="hidden" name="documentType" value="driverLicense">
                    <textarea name="reason" placeholder="Rejection reason..." required></textarea>
                    <button type="submit" class="btn btn-danger">Reject License</button>
                </form>
            <% } %>
        </div>
        <% } %>

        <!-- Selfie Section -->
        <% const biometrics = runner.runnerProfile?.biometricVerification || {}; %>
        <% if (biometrics.selfiePath) { %>
        <div class="section">
            <h2>Selfie Verification</h2>
            <div class="info-row"><label>Status:</label> <%= biometrics.status %></div>
            <div class="info-row"><label>Submitted:</label> <%= new Date(biometrics.submittedAt).toLocaleString() %></div>
            
            <img src="<%= biometrics.selfiePath %>" alt="Selfie" class="doc-image">
            
            <% if (biometrics.status === 'pending_review') { %>
                <form method="POST" action="/admin/kyc/approve-selfie/<%= runner._id %>" style="display: inline;">
                    <button type="submit" class="btn btn-success">Approve Selfie</button>
                </form>
                <form method="POST" action="/admin/kyc/reject-selfie/<%= runner._id %>" style="display: inline;">
                    <textarea name="reason" placeholder="Rejection reason..." required></textarea>
                    <button type="submit" class="btn btn-danger">Reject Selfie</button>
                </form>
            <% } %>
        </div>
        <% } %>
    </div>
</body>
</html>