{
  "name": "sendrey-server",
  "version": "1.0.0",
  "main": "app.js",
  "scripts": {
    "dev": "nodemon app.js",
    "admin": "nodemon adminServer.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run admin\"",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch --runInBand",
    "test:coverage": "jest --coverage --runInBand --forceExit"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "setupFilesAfterEnv": [
      "./tests/setup.js"
    ],
    "testTimeout": 60000,
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "services/**/*.js",
      "controllers/**/*.js",
      "socket/**/*.js",
      "middleware/**/*.js"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "agora-access-token": "^2.0.4",
    "agora-rtc-sdk-ng": "^4.24.2",
    "axios": "^1.13.4",
    "bcryptjs": "^2.4.3",
    "check-password-strength": "^2.0.0",
    "cloudinary": "^2.9.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "~8.2.0",
    "ejs": "^4.0.1",
    "express": "^4.18.0",
    "express-rate-limit": "^6.0.0",
    "firebase-admin": "^13.6.1",
    "fs": "^0.0.1-security",
    "geoip-lite": "^1.4.0",
    "googleapis": "^171.4.0",
    "handlebars": "^4.7.8",
    "helmet": "^6.0.0",
    "ioredis": "^5.9.3",
    "joi": "^17.9.0",
    "jsonwebtoken": "^9.0.0",
    "kafkajs": "^2.2.4",
    "libphonenumber-js": "^1.12.23",
    "mongodb": "^6.20.0",
    "mongoose": "^7.0.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^6.10.1",
    "path": "^0.12.7",
    "socket.io": "^4.8.1",
    "streamifier": "^0.1.1",
    "stripe": "^20.3.1",
    "twilio": "^4.0.0",
    "winston": "^3.8.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "concurrently": "^9.2.1",
    "dotenv-safe": "^9.1.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^2.0.0",
    "supertest": "^7.2.2"
  }
}
